/* ══════════════════════════════════════
   登录页面 - 美化版样式
   ══════════════════════════════════════ */

.page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0ecff 0%, #f2f2f7 40%);
}

.content {
  position: relative;
  z-index: 1;
  padding: 0 40rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* ── Logo ── */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 72rpx;
}

.logo-icon {
  width: 144rpx;
  height: 144rpx;
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(108,92,231,0.3);
}

.logo-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.logo-sub {
  font-size: 26rpx;
  color: #999;
}

/* ── 小 Logo ── */
.logo-area-small {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.logo-icon-small {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

/* ── 表单 ── */
.form-area {
  width: 100%;
}

.input-group {
  margin-bottom: 20rpx;
  position: relative;
}

.input-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.input-field {
  background: #fff;
  border: 2rpx solid #e5e5ea;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
  color: #1a1a1a;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.input-field:focus {
  border-color: #6C5CE7;
  box-shadow: 0 0 0 4rpx rgba(108,92,231,0.1);
}

.input-hint {
  font-size: 24rpx;
  color: #e74c3c;
  margin-top: 8rpx;
  display: block;
  padding-left: 8rpx;
}

.toggle-password {
  position: absolute;
  right: 24rpx;
  top: 64rpx;
  font-size: 32rpx;
  z-index: 2;
}

.info-box {
  display: flex;
  align-items: center;
  background: rgba(108,92,231,0.06);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 14rpx;
}

.info-text {
  font-size: 24rpx;
  color: #6C5CE7;
}

.connect-btn {
  margin-top: 12rpx;
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%) !important;
  color: #fff !important;
  border: none !important;
  border-radius: 20rpx !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
  font-size: 32rpx !important;
  font-weight: 700 !important;
  box-shadow: 0 8rpx 28rpx rgba(108,92,231,0.3) !important;
}

.connect-btn[disabled] {
  opacity: 0.5 !important;
  box-shadow: none !important;
}

/* ── 用户列表 ── */
.user-list {
  margin-bottom: 24rpx;
}

.user-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.user-card:active {
  background: #f8f8f8;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 4rpx;
}

.user-handle {
  font-size: 24rpx;
  color: #999;
}

.user-badge {
  background: #f0f0f0;
  font-size: 20rpx;
  color: #999;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  margin-right: 12rpx;
}

.user-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* ── 选中用户 ── */
.selected-user-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.user-avatar-large {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.selected-user-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a1a;
  margin-bottom: 6rpx;
}

.selected-user-handle {
  font-size: 26rpx;
  color: #999;
}

/* ── 底部操作 ── */
.bottom-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.btn-text {
  background: transparent;
  border: none;
  color: #999;
  font-size: 26rpx;
  padding: 16rpx;
}

.btn-tonal {
  background: rgba(108,92,231,0.08);
  color: #6C5CE7;
  border: none;
  border-radius: 20rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  width: 100%;
}

/* ── 加载 ── */
.loading-mask {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #e5e5ea;
  border-top-color: #6C5CE7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* ── 空状态 ── */
.empty-icon-text {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.2;
}

/* ── 错误提示 ── */
.error-toast {
  position: fixed;
  bottom: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(231,76,60,0.9);
  color: #fff;
  padding: 20rpx 36rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  z-index: 999;
  max-width: 80%;
  text-align: center;
  backdrop-filter: blur(10px);
}
