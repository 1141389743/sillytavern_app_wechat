<!--
  AI 后端配置页面（美化版）
  服务端模式：配置保存到 SillyTavern，聊天记录自动同步
  直连模式：小程序独立调用 AI
-->
<view class="page">
  <!-- 顶部模式切换 Tab -->
  <view class="mode-tabs">
    <view class="mode-tab {{!useDirectApi ? 'tab-active' : ''}}" bindtap="onSelectMode" data-mode="st">
      <text class="tab-icon">📡</text>
      <text class="tab-text">服务端</text>
      <text class="tab-desc">配置同步到服务器</text>
    </view>
    <view class="mode-tab {{useDirectApi ? 'tab-active' : ''}}" bindtap="onSelectMode" data-mode="direct">
      <text class="tab-icon">🔌</text>
      <text class="tab-text">直连</text>
      <text class="tab-desc">小程序独立调用</text>
    </view>
  </view>

  <view class="container">
    <!-- ═══════════════════════════════════ -->
    <!-- SillyTavern 服务端模式              -->
    <!-- ═══════════════════════════════════ -->
    <view wx:if="{{!useDirectApi}}">
      <!-- 后端类型选择卡片 -->
      <view class="section-header">
        <text class="section-icon">🤖</text>
        <text class="section-title">选择 AI 后端</text>
      </view>

      <view class="backend-grid">
        <view
          class="backend-card {{item.active ? 'backend-card-active' : ''}}"
          wx:for="{{backends}}"
          wx:key="id"
          bindtap="onSelectBackend"
          data-id="{{item.id}}"
        >
          <view class="backend-card-icon">{{item.icon}}</view>
          <view class="backend-card-name">{{item.name}}</view>
          <view class="backend-card-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
          <view class="backend-card-check" wx:if="{{item.active}}">✓</view>
        </view>
      </view>

      <!-- API 配置表单 -->
      <view class="config-card" wx:if="{{showApiForm}}">
        <view class="config-header">
          <text class="config-icon">{{currentBackendIcon}}</text>
          <view class="config-title-wrap">
            <text class="config-title">{{currentBackendName}}</text>
            <text class="config-sub">填写后保存到服务端</text>
          </view>
        </view>

        <!-- API Key -->
        <view class="field-group" wx:if="{{needApiKey}}">
          <text class="field-label">🔑 API Key</text>
          <view class="field-input-wrap">
            <input
              class="field-input"
              placeholder="{{apiKeyPlaceholder}}"
              value="{{stApiKey}}"
              bindinput="onStApiKeyInput"
              bindfocus="onInputFocus"
              password="{{!showStApiKey}}"
            />
            <view class="field-eye" bindtap="toggleStApiKey">
              <text>{{showStApiKey ? '🙈' : '👁️'}}</text>
            </view>
          </view>
        </view>

        <!-- API URL -->
        <view class="field-group" wx:if="{{needApiUrl}}">
          <text class="field-label">🌐 API 地址</text>
          <input
            class="field-input"
            placeholder="{{apiUrlPlaceholder}}"
            value="{{stApiUrl}}"
            bindinput="onStApiUrlInput"
            bindfocus="onInputFocus"
          />
        </view>

        <!-- 模型名 -->
        <view class="field-group" wx:if="{{needModel}}">
          <text class="field-label">🧠 模型</text>
          <input
            class="field-input"
            placeholder="{{modelPlaceholder}}"
            value="{{stModel}}"
            bindinput="onStModelInput"
            bindfocus="onInputFocus"
          />
        </view>

        <!-- 按钮行 -->
        <view class="btn-row">
          <button class="btn-test" bindtap="onTestServerConnection" loading="{{isTesting}}" disabled="{{isTesting}}">
            {{isTesting ? '测试中...' : '🔗 测试连接'}}
          </button>
          <button class="btn-save" bindtap="onSaveToServer" loading="{{isSaving}}" disabled="{{isSaving}}">
            {{isSaving ? '保存中...' : '💾 保存'}}
          </button>
        </view>

        <!-- 结果提示 -->
        <view class="result-box result-ok" wx:if="{{saveResult && saveSuccess}}">
          <text class="result-icon">✅</text>
          <text class="result-text">{{saveResult}}</text>
        </view>
        <view class="result-box result-err" wx:if="{{saveResult && !saveSuccess}}">
          <text class="result-icon">❌</text>
          <text class="result-text">{{saveResult}}</text>
        </view>
        <view class="result-box result-ok" wx:if="{{testResult && testSuccess}}">
          <text class="result-icon">✅</text>
          <text class="result-text">{{testResult}}</text>
        </view>
        <view class="result-box result-err" wx:if="{{testResult && !testSuccess}}">
          <text class="result-icon">❌</text>
          <text class="result-text" style="white-space:pre-wrap;">{{testResult}}</text>
        </view>
      </view>

      <!-- 说明卡片 -->
      <view class="tip-card">
        <text class="tip-icon">💡</text>
        <view class="tip-content">
          <text class="tip-title">服务端模式说明</text>
          <text class="tip-text">配置保存到 SillyTavern 后，网页端和小程序共享同一配置。所有聊天记录自动保存在服务端。</text>
        </view>
      </view>
    </view>

    <!-- ═══════════════════════════════════ -->
    <!-- 直连 AI API 模式                    -->
    <!-- ═══════════════════════════════════ -->
    <view wx:if="{{useDirectApi}}">
      <view class="section-header">
        <text class="section-icon">🔌</text>
        <text class="section-title">直连 AI 配置</text>
      </view>

      <!-- API 类型选择 -->
      <view class="type-scroll">
        <view
          class="type-chip {{index === apiTypeIndex ? 'type-chip-active' : ''}}"
          wx:for="{{apiTypeNames}}"
          wx:key="index"
          bindtap="onApiTypeChange"
          data-index="{{index}}"
        >
          {{item}}
        </view>
      </view>

      <!-- 配置表单 -->
      <view class="config-card">
        <!-- API 地址 -->
        <view class="field-group">
          <text class="field-label">🌐 API 地址</text>
          <input
            class="field-input"
            placeholder="例如: https://api.openai.com"
            value="{{apiBaseUrl}}"
            bindinput="onApiBaseUrlInput"
            bindfocus="onInputFocus"
          />
        </view>

        <!-- API Key -->
        <view class="field-group">
          <text class="field-label">🔑 API Key</text>
          <view class="field-input-wrap">
            <input
              class="field-input"
              placeholder="sk-..."
              value="{{apiKey}}"
              bindinput="onApiKeyInput"
              bindfocus="onInputFocus"
              password="{{!showApiKey}}"
            />
            <view class="field-eye" bindtap="toggleApiKey">
              <text>{{showApiKey ? '🙈' : '👁️'}}</text>
            </view>
          </view>
        </view>

        <!-- 模型 -->
        <view class="field-group">
          <text class="field-label">🧠 模型</text>
          <input
            class="field-input"
            placeholder="例如: gpt-4o-mini / deepseek-chat"
            value="{{modelName}}"
            bindinput="onModelInput"
            bindfocus="onInputFocus"
          />
        </view>

        <!-- 测试 + 保存 -->
        <view class="btn-row">
          <button class="btn-test" bindtap="onTestConnection" loading="{{isTesting}}" disabled="{{isTesting}}">
            {{isTesting ? '测试中...' : '🔗 测试'}}
          </button>
          <button class="btn-save" bindtap="onSaveLocal">
            💾 保存
          </button>
        </view>

        <!-- 测试结果 -->
        <view class="result-box result-ok" wx:if="{{testResult && testSuccess}}">
          <text class="result-icon">✅</text>
          <text class="result-text">{{testResult}}</text>
        </view>
        <view class="result-box result-err" wx:if="{{testResult && !testSuccess}}">
          <text class="result-icon">❌</text>
          <text class="result-text">{{testResult}}</text>
        </view>
      </view>

      <!-- 说明 -->
      <view class="tip-card">
        <text class="tip-icon">💡</text>
        <view class="tip-content">
          <text class="tip-title">直连模式说明</text>
          <text class="tip-text">小程序直接调用 AI API，不经过 SillyTavern。对话记录不会同步到服务端，仅保存在小程序内。</text>
        </view>
      </view>
    </view>
    <!-- ═══════════════════════════════════ -->
    <!-- TTS 语音朗读配置                    -->
    <!-- ═══════════════════════════════════ -->
    <view class="section-header" style="margin-top:32rpx;" bindtap="onToggleTtsSection">
      <text class="section-icon">🔊</text>
      <text class="section-title">语音朗读 (TTS)</text>
      <text class="section-arrow">{{showTtsSection ? '▲' : '▼'}}</text>
    </view>

    <view wx:if="{{showTtsSection}}">
      <!-- 后端选择 -->
      <view class="config-card">
        <view class="field-group">
          <text class="field-label">🎤 TTS 引擎</text>
          <view class="type-scroll">
            <view class="type-chip {{ttsBackend === 'edge' ? 'type-chip-active' : ''}}" bindtap="onTtsBackendChange" data-value="edge">Edge TTS (免费)</view>
            <view class="type-chip {{ttsBackend === 'openai' ? 'type-chip-active' : ''}}" bindtap="onTtsBackendChange" data-value="openai">OpenAI TTS</view>
            <view class="type-chip {{ttsBackend === 'custom' ? 'type-chip-active' : ''}}" bindtap="onTtsBackendChange" data-value="custom">自定义</view>
          </view>
        </view>

        <!-- OpenAI TTS 配置 -->
        <view wx:if="{{ttsBackend === 'openai'}}">
          <view class="field-group">
            <text class="field-label">🌐 API 地址</text>
            <input class="field-input" placeholder="https://api.openai.com" value="{{ttsOpenaiBaseUrl}}" bindinput="onTtsOpenaiBaseUrlInput" />
          </view>
          <view class="field-group">
            <text class="field-label">🔑 API Key</text>
            <view class="field-input-wrap">
              <input class="field-input" placeholder="sk-..." value="{{ttsOpenaiApiKey}}" bindinput="onTtsOpenaiApiKeyInput" password="{{!showTtsApiKey}}" />
              <view class="field-eye" bindtap="toggleTtsApiKey"><text>{{showTtsApiKey ? '🙈' : '👁️'}}</text></view>
            </view>
          </view>
          <view class="field-group">
            <text class="field-label">🧠 模型</text>
            <input class="field-input" placeholder="tts-1" value="{{ttsOpenaiModel}}" bindinput="onTtsOpenaiModelInput" />
          </view>
        </view>

        <!-- 自定义 TTS 配置 -->
        <view wx:if="{{ttsBackend === 'custom'}}">
          <view class="field-group">
            <text class="field-label">🌐 TTS API 地址</text>
            <input class="field-input" placeholder="https://your-tts-api.com/synthesize" value="{{ttsCustomUrl}}" bindinput="onTtsCustomUrlInput" />
          </view>
        </view>

        <!-- 音色选择 -->
        <view class="field-group">
          <text class="field-label">🎵 音色</text>
          <picker range="{{ttsVoices}}" range-key="name" bindchange="onTtsVoiceChange">
            <view class="picker-value">
              {{ttsVoices[ttsVoice] || ttsVoice}}
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
          <!-- 音色列表展示 -->
          <view class="voice-grid">
            <view
              class="voice-chip {{item.id === ttsVoice ? 'voice-chip-active' : ''}}"
              wx:for="{{ttsVoices}}"
              wx:key="id"
              bindtap="onTtsVoiceChange"
              data-index="{{index}}"
            >
              <text class="voice-name">{{item.name}}</text>
              <text class="voice-desc">{{item.desc}}</text>
            </view>
          </view>
        </view>

        <!-- 语速 -->
        <view class="field-group">
          <text class="field-label">⚡ 语速: {{ttsSpeed}}x</text>
          <slider min="0.5" max="2.0" step="0.1" value="{{ttsSpeed}}" bindchange="onTtsSpeedChange" activeColor="#6C5CE7" show-value="true" />
        </view>

        <!-- AI 情感分析 -->
        <view class="field-group">
          <view class="field-row">
            <view>
              <text class="field-label">🎭 AI 情感解读</text>
              <text class="field-hint">让 AI 先分析文本情感再朗读（消耗 1 次 API 调用）</text>
            </view>
            <switch checked="{{ttsEnableEmotion}}" bindchange="onTtsEmotionToggle" color="#6C5CE7" />
          </view>
        </view>

        <!-- 测试 + 保存 -->
        <view class="btn-row">
          <button class="btn-test" bindtap="onTestTts" loading="{{isTestingTts}}" disabled="{{isTestingTts}}">
            {{isTestingTts ? '合成中...' : '🔊 测试朗读'}}
          </button>
          <button class="btn-save" bindtap="onSaveTts">💾 保存</button>
        </view>

        <!-- 测试结果 -->
        <view class="result-box result-ok" wx:if="{{ttsTestResult && ttsTestSuccess}}">
          <text class="result-icon">✅</text>
          <text class="result-text">{{ttsTestResult}}</text>
        </view>
        <view class="result-box result-err" wx:if="{{ttsTestResult && !ttsTestSuccess}}">
          <text class="result-icon">❌</text>
          <text class="result-text">{{ttsTestResult}}</text>
        </view>
      </view>

      <!-- TTS 说明 -->
      <view class="tip-card">
        <text class="tip-icon">💡</text>
        <view class="tip-content">
          <text class="tip-title">语音朗读说明</text>
          <text class="tip-text">在聊天页长按 AI 消息 → 选择「🔊 朗读」即可。Edge TTS 免费无需 API Key，支持中英日多种音色。开启「AI 情感解读」后，大模型会先分析文本情感再合成语音，效果更生动。</text>
        </view>
      </view>
    </view>
  </view>
</view>
