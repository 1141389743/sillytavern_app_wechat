<!--
  角色列表页面（美化版）
-->
<view class="page">
  <!-- 顶部搜索 + 状态 -->
  <view class="top-bar">
    <view class="search-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索角色..."
        value="{{searchQuery}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <view class="search-clear" wx:if="{{searchQuery}}" bindtap="clearSearch">✕</view>
    </view>
    <view class="status-btn" bindtap="onShowSettings">
      <text class="status-dot {{isConnected ? 'dot-green' : 'dot-red'}}"></text>
      <text class="status-label">{{isConnected ? '已连接' : '离线'}}</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-area" wx:if="{{isLoading}}">
    <view class="spinner"></view>
    <text class="loading-text">加载角色列表...</text>
  </view>

  <!-- 角色列表 -->
  <scroll-view
    class="char-list"
    scroll-y
    wx:if="{{!isLoading && filteredChars.length > 0}}"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{isRefreshing}}"
  >
    <view
      class="char-card"
      wx:for="{{filteredChars}}"
      wx:key="name"
      bindtap="onTapCharacter"
      data-index="{{index}}"
      bindlongpress="onLongPressCharacter"
      data-char="{{item}}"
    >
      <!-- 头像 -->
      <view class="char-avatar-wrap">
        <image
          wx:if="{{item._avatarPath && !item._avatarFailed}}"
          class="char-avatar"
          src="{{item._avatarPath}}"
          mode="aspectFill"
        />
        <view class="char-avatar-fallback" wx:else>
          <text class="avatar-letter">{{item.name[0] || '?'}}</text>
        </view>
        <!-- 加载中小点 -->
        <view class="avatar-loading" wx:if="{{!item._avatarPath && !item._avatarFailed && item.avatar}}"></view>
      </view>

      <!-- 信息 -->
      <view class="char-info">
        <text class="char-name">{{item.name}}</text>
        <text class="char-desc">{{item._summary}}</text>
      </view>

      <text class="char-arrow">›</text>
    </view>
  </scroll-view>

  <!-- 空状态 -->
  <view class="empty-area" wx:if="{{!isLoading && filteredChars.length === 0}}">
    <text class="empty-icon">{{searchQuery ? '🔍' : '👤'}}</text>
    <text class="empty-title">{{searchQuery ? '没有匹配的角色' : '服务器上没有角色'}}</text>
    <text class="empty-hint" wx:if="{{!searchQuery}}">点击下方按钮添加角色</text>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <button class="btn-action btn-import" bindtap="onImport">
      <text class="btn-icon">📥</text>
      <text>导入</text>
    </button>
    <button class="btn-action btn-create" bindtap="onCreate">
      <text class="btn-icon">➕</text>
      <text>新建</text>
    </button>
  </view>

  <!-- ═══ 设置弹窗 ═══ -->
  <view class="overlay" wx:if="{{showSettings}}" bindtap="hideSettings">
    <view class="sheet" catchtap="">
      <view class="sheet-handle"></view>
      <view class="sheet-item" bindtap="onReconnect">
        <text class="sheet-icon">🔄</text>
        <view class="sheet-text">
          <text class="sheet-title">重新连接</text>
          <text class="sheet-sub">{{serverUrl}}</text>
        </view>
      </view>
      <view class="sheet-item" bindtap="onOpenApiSettings">
        <text class="sheet-icon">⚙️</text>
        <view class="sheet-text">
          <text class="sheet-title">AI 后端配置</text>
          <text class="sheet-sub">{{useDirectApi ? '直连: ' + directApiTypeName : '服务端后端'}}</text>
        </view>
      </view>
      <view class="sheet-divider"></view>
      <view class="sheet-item" bindtap="onSwitchAccount">
        <text class="sheet-icon">🔄</text>
        <text class="sheet-title" style="color:#e17055">切换账号</text>
      </view>
      <view class="sheet-item" bindtap="onChangeServer">
        <text class="sheet-icon">⚙️</text>
        <text class="sheet-title">修改服务器地址</text>
      </view>
    </view>
  </view>

  <!-- ═══ 角色操作弹窗 ═══ -->
  <view class="overlay" wx:if="{{showCharMenu}}" bindtap="hideCharMenu">
    <view class="sheet" catchtap="">
      <view class="sheet-handle"></view>
      <view class="sheet-title-area">
        <text class="sheet-main-title">{{selectedCharForMenu.name}}</text>
      </view>
      <view class="sheet-item" bindtap="onEditCharacter">
        <text class="sheet-icon">✏️</text>
        <text class="sheet-title">编辑角色</text>
      </view>
      <view class="sheet-item" bindtap="onDeleteCharacter">
        <text class="sheet-icon">🗑️</text>
        <text class="sheet-title" style="color:#e74c3c">删除角色</text>
      </view>
    </view>
  </view>
</view>
