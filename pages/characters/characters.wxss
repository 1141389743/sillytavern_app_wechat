/* ══════════════════════════════════════
   角色列表 - 美化版样式
   ══════════════════════════════════════ */

.page {
  min-height: 100vh;
  background: #f2f2f7;
  display: flex;
  flex-direction: column;
}

/* ── 顶部搜索栏 ── */
.top-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  gap: 16rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}

.search-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f7;
  border-radius: 20rpx;
  padding: 14rpx 20rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  background: transparent;
  border: none;
  padding: 0;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
}

.status-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 20rpx;
  background: #f5f5f7;
  border-radius: 20rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot-green {
  background: #27ae60;
  box-shadow: 0 0 8rpx rgba(39,174,96,0.5);
}

.dot-red {
  background: #e74c3c;
  box-shadow: 0 0 8rpx rgba(231,76,60,0.5);
}

.status-label {
  font-size: 24rpx;
  color: #666;
}

/* ── 加载 ── */
.loading-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #e5e5ea;
  border-top-color: #6C5CE7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ── 角色列表 ── */
.char-list {
  flex: 1;
  padding: 16rpx 24rpx;
}

.char-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: transform 0.15s;
}

.char-card:active {
  transform: scale(0.98);
}

/* ── 头像 ── */
.char-avatar-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 22rpx;
  overflow: hidden;
  margin-right: 24rpx;
  flex-shrink: 0;
  position: relative;
  background: #f0f0f0;
}

.char-avatar {
  width: 112rpx;
  height: 112rpx;
}

.char-avatar-fallback {
  width: 112rpx;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #dfe6e9 0%, #b2bec3 100%);
}

.avatar-letter {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.avatar-loading {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid rgba(255,255,255,0.6);
  border-top-color: #6C5CE7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* ── 角色信息 ── */
.char-info {
  flex: 1;
  min-width: 0;
}

.char-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.char-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.char-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ── 空状态 ── */
.empty-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 96rpx;
  opacity: 0.25;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
}

/* ── 底部按钮 ── */
.bottom-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid rgba(0,0,0,0.04);
}

.btn-action {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 20rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  line-height: 1.5;
}

.btn-import {
  background: #f5f5f7;
  color: #333;
}

.btn-create {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(108,92,231,0.25);
}

.btn-icon {
  font-size: 28rpx;
}

/* ── 弹窗 ── */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 12rpx 0;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.sheet-handle {
  width: 64rpx;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  margin: 12rpx auto 20rpx;
}

.sheet-title-area {
  padding: 12rpx 40rpx 16rpx;
}

.sheet-main-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.sheet-item {
  display: flex;
  align-items: center;
  padding: 26rpx 40rpx;
}

.sheet-item:active {
  background: #f5f5f7;
}

.sheet-icon {
  font-size: 32rpx;
  margin-right: 24rpx;
}

.sheet-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.sheet-title {
  font-size: 30rpx;
  color: #1a1a1a;
}

.sheet-sub {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.sheet-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 8rpx 40rpx;
}
