<!--
  聊天页面 - 对应 Flutter chat_screen.dart
  v2: 流式输出 + 重新生成 + 编辑消息
-->
<view class="page">
  <!-- 顶部角色信息 -->
  <view class="chat-header">
    <view class="header-back" bindtap="onBack">←</view>
    <view class="header-avatar" wx:if="{{characterAvatarUrl}}">
      <image src="{{characterAvatarUrl}}" mode="aspectFill" class="header-avatar-img" />
    </view>
    <view class="header-avatar header-avatar-placeholder" wx:else>
      {{characterName[0] || '?'}}
    </view>
    <view class="header-info">
      <text class="header-name">{{characterName}}</text>
      <text class="header-status {{isSending ? 'status-sending' : ''}}">
        {{isStreaming ? '正在回复...' : isSending ? '正在输入...' : (useDirectApi ? '直连: ' + directApiTypeName : '酒馆后端')}}
      </text>
    </view>
    <view class="header-action" bindtap="onShowCharacterInfo">ℹ️</view>
  </view>

  <!-- 开场白横幅 -->
  <view class="greeting-banner" wx:if="{{greeting && messages.length === 0}}">
    <view class="greeting-header">
      <text class="greeting-star">✨</text>
      <text class="greeting-name">{{characterName}}</text>
    </view>
    <text class="greeting-text">{{greeting}}</text>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="message-list"
    scroll-y
    scroll-top="{{scrollTop}}"
    scroll-into-view="{{scrollToId}}"
    scroll-with-animation
    enhanced
    show-scrollbar="{{false}}"
    refresher-enabled
    refresher-triggered="{{isRefreshing}}"
    bindrefresherrefresh="onPullRefresh"
  >
    <!-- 下拉刷新提示 -->
    <view class="refresh-tip" wx:if="{{isRefreshing}}">
      <text>🔄 加载聊天记录中...</text>
    </view>
    <!-- 空状态 -->
    <view class="empty-chat" wx:if="{{messages.length === 0}}">
      <text class="empty-chat-icon">💬</text>
      <text class="empty-chat-text">{{greeting || '发送一条消息开始对话吧'}}</text>
    </view>

    <!-- 消息气泡 -->
    <view
      wx:for="{{messages}}"
      wx:key="id"
      id="msg-{{item.id}}"
      class="msg-row {{item.role === 'user' ? 'msg-row-user' : item.role === 'system' ? 'msg-row-system' : 'msg-row-assistant'}}"
    >
      <!-- 系统消息 -->
      <view wx:if="{{item.role === 'system'}}" class="system-msg">
        <text selectable>{{item.content}}</text>
      </view>

      <!-- 非系统消息 -->
      <block wx:if="{{item.role !== 'system'}}">
        <!-- 角色头像（助手消息） -->
        <view class="msg-avatar" wx:if="{{item.role === 'assistant' && item._showAvatar}}">
          <text>{{characterName[0]}}</text>
        </view>
        <view class="msg-avatar-space" wx:if="{{item.role === 'assistant' && !item._showAvatar}}"></view>

        <view class="msg-bubble-wrap {{item.role === 'user' ? 'bubble-user' : 'bubble-assistant'}}">
          <!-- 角色名 -->
          <text class="msg-name" wx:if="{{item.role === 'assistant'}}">{{characterName}}</text>
          <!-- 消息内容 -->
          <view class="msg-content" bindlongpress="onLongPressMessage" data-id="{{item.id}}" data-content="{{item.content}}" data-role="{{item.role}}">
            <!-- 助手消息用 rich-text 渲染 Markdown -->
            <rich-text wx:if="{{item.role === 'assistant'}}" nodes="{{item._mdWxml || item.content}}" selectable bindlongpress="onLongPressMessage" data-id="{{item.id}}" data-content="{{item.content}}" data-role="{{item.role}}" />
            <!-- 用户消息用纯文本 -->
            <text wx:else selectable>{{item.content}}</text>
            <!-- 流式光标 -->
            <text wx:if="{{item._isStreaming}}" class="streaming-cursor">▊</text>
          </view>
        </view>

        <!-- 用户头像 -->
        <view class="msg-avatar msg-avatar-user" wx:if="{{item.role === 'user'}}">
          <text>我</text>
        </view>

        <!-- 时间 -->
        <text class="msg-time {{item.role === 'user' ? 'time-right' : 'time-left'}}">
          {{item._time}}
        </text>
      </block>
    </view>

    <!-- 发送中指示（非流式模式时显示） -->
    <view class="typing-indicator" wx:if="{{isSending && !isStreaming}}">
      <view class="typing-avatar">
        <text>{{characterName[0]}}</text>
      </view>
      <view class="typing-bubble">
        <view class="typing-dots">
          <view class="dot dot1"></view>
          <view class="dot dot2"></view>
          <view class="dot dot3"></view>
        </view>
      </view>
    </view>

    <!-- 底部操作栏：重新生成 + 停止 -->
    <view class="bottom-actions" wx:if="{{messages.length > 0}}">
      <view class="action-btn" wx:if="{{!isSending && messages.length >= 2}}" bindtap="onRegenerate">
        <text class="action-icon">🔄</text>
        <text class="action-text">重新生成</text>
      </view>
      <view class="action-btn action-btn-stop" wx:if="{{isStreaming}}" bindtap="onStopStreaming">
        <text class="action-icon">⏹</text>
        <text class="action-text">停止生成</text>
      </view>
    </view>

    <!-- 底部占位 -->
    <view id="msg-bottom" style="height:20rpx;"></view>
  </scroll-view>

  <!-- 编辑消息浮层 -->
  <view class="edit-overlay" wx:if="{{editingMessageId}}">
    <view class="edit-header">
      <text class="edit-label">编辑消息</text>
      <view class="edit-close" bindtap="onCancelEdit">✕</view>
    </view>
    <view class="edit-body">
      <textarea
        class="edit-input"
        value="{{editingText}}"
        bindinput="onEditInput"
        auto-height
        maxlength="8000"
        focus
        show-confirm-bar="{{false}}"
      />
    </view>
    <view class="edit-actions">
      <button class="btn-cancel" bindtap="onCancelEdit">取消</button>
      <button class="btn-save" bindtap="onSaveEdit">保存并重新生成</button>
    </view>
  </view>

  <!-- 消息长按菜单 -->
  <view class="msg-menu-mask" wx:if="{{showMsgMenu}}" bindtap="hideMsgMenu">
    <view class="msg-menu" catchtap="">
      <view class="msg-menu-item" bindtap="onMenuEdit">
        <text class="menu-icon">✏️</text>
        <text>编辑</text>
      </view>
      <view class="msg-menu-item" bindtap="onMenuCopy">
        <text class="menu-icon">📋</text>
        <text>复制</text>
      </view>
      <view class="msg-menu-item menu-item-danger" bindtap="onMenuDelete">
        <text class="menu-icon">🗑️</text>
        <text>删除</text>
      </view>
    </view>
  </view>

  <!-- 输入区域 -->
  <view class="input-area" wx:if="{{!editingMessageId}}">
    <view class="input-wrap">
      <textarea
        class="msg-input"
        placeholder="输入消息..."
        value="{{inputText}}"
        focus="{{inputFocused}}"
        bindinput="onInput"
        bindconfirm="onSend"
        confirm-type="send"
        auto-height
        maxlength="4000"
        show-confirm-bar="{{false}}"
        adjust-position="{{true}}"
        cursor-spacing="20"
        bindblur="onInputBlur"
      />
    </view>
    <view
      class="send-btn {{canSend ? 'send-btn-active' : ''}}"
      bindtap="onSend"
    >
      <text>{{isSending ? '⏳' : '📤'}}</text>
    </view>
  </view>

  <!-- 角色信息弹窗 -->
  <view class="settings-mask" wx:if="{{showCharInfo}}" bindtap="hideCharInfo">
    <view class="info-sheet" catchtap="">
      <view class="sheet-handle"></view>
      <text class="info-title">{{characterName}}</text>
      <text class="info-desc" wx:if="{{characterDescription}}">{{characterDescription}}</text>
      <text class="info-field" wx:if="{{characterPersonality}}">性格: {{characterPersonality}}</text>
      <text class="info-field" wx:if="{{characterScenario}}">场景: {{characterScenario}}</text>
      <button class="btn-primary mt-24" bindtap="hideCharInfo">知道了</button>
    </view>
  </view>
</view>
