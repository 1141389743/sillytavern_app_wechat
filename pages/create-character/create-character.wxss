/* 创建角色页面样式 */

.page {
  min-height: 100vh;
  background: var(--surface-variant);
}

.container {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* 头像选择 */
.avatar-area {
  width: 100%;
  height: 240rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  border: 2rpx dashed var(--outline);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-preview {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
  opacity: 0.5;
}

.avatar-hint {
  font-size: 26rpx;
  color: var(--on-surface-secondary);
}

/* 输入 */
.input-group {
  margin-bottom: 20rpx;
}

.input-label {
  font-size: 26rpx;
  color: var(--on-surface-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.input-field {
  background: var(--surface);
  border: 2rpx solid var(--outline);
  border-radius: 20rpx;
  padding: 22rpx 26rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.textarea {
  min-height: 120rpx;
  line-height: 1.5;
}

.textarea-tall {
  min-height: 200rpx;
}

/* 保存按钮 */
.save-btn {
  margin-top: 24rpx;
}
